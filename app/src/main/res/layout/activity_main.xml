<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1320"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Video "
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#F8FAFC" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Editor Pro"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#3B82F6" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#0F172A">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="⚡ FFmpeg-Kit Engine"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#2DD4BF" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- FILE SELECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="16dp">
            
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1D4ED8">
                <LinearLayout
                    android:id="@+id/btnSelectVideo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎬 PILIH VIDEO (1)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilih satu video untuk diedit"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"
                        android:textColor="#BFDBFE" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#6D28D9">
                <LinearLayout
                    android:id="@+id/btnSelectMultiVideo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📂 PILIH MULTI (BATCH)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilih banyak video sekaligus"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"
                        android:textColor="#DDD6FE" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSelectedFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="[ Kosong ]"
            android:textColor="#EF4444"
            android:textStyle="italic"
            android:gravity="center"/>

        <!-- TV PREVIEW CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#141D2E"
            app:cardElevation="0dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📺 PREVIEW VIDEO"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#F8FAFC"
                    android:layout_marginBottom="12dp"/>
                
                <!-- Tinggi video dibesarkan ke 350dp -->
                <VideoView
                    android:id="@+id/videoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:layout_gravity="center"/>
                
                <SeekBar
                    android:id="@+id/seekBarPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:progressTint="#3B82F6"
                    android:thumbTint="#3B82F6"
                    android:paddingHorizontal="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <Button
                        android:id="@+id/btnPlayPause"
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        android:text="▶ PLAY"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2563EB"/>
                    <TextView
                        android:id="@+id/tvPreviewTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="00:00.000 / 00:00.000"
                        android:textColor="#38BDF8"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TRIM CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#141D2E"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✂️ MODE POTONG (TRIM)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#F8FAFC"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Potong video sesuai kebutuhan Anda"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="12dp"/>
                
                <RadioGroup
                    android:id="@+id/rgTrimMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <RadioButton
                        android:id="@+id/rbTrimAuto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Auto Split (Potong berkali-kali per part)\nVideo akan dipotong otomatis per interval"
                        android:textColor="#E2E8F0"
                        android:buttonTint="#3B82F6"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>
                    <RadioButton
                        android:id="@+id/rbTrimCustom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Spesifik (Potong dari titik A ke B)\nPilih start &amp; end point secara manual"
                        android:buttonTint="#3B82F6"
                        android:textColor="#E2E8F0"/>
                </RadioGroup>

                <LinearLayout
                    android:id="@+id/layoutTrimAuto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">
                    <EditText
                        android:id="@+id/etTrimSegment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:textSize="14sp"
                        android:hint="Masukkan durasi per part (detik)"
                        android:textColorHint="#64748B"
                        android:textColor="#F8FAFC"
                        android:inputType="numberDecimal"
                        android:background="#0B1320"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="16dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutTrimCustom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        <EditText
                            android:id="@+id/etTrimStart"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:minHeight="50dp"
                            android:layout_marginEnd="6dp"
                            android:textSize="14sp"
                            android:hint="Start (misal: 5.150)"
                            android:textColorHint="#64748B"
                            android:textColor="#F8FAFC"
                            android:inputType="numberDecimal"
                            android:background="#0B1320"
                            android:paddingHorizontal="16dp"/>
                        <EditText
                            android:id="@+id/etTrimEnd"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:minHeight="50dp"
                            android:textSize="14sp"
                            android:hint="End (misal: 6.900)"
                            android:textColorHint="#64748B"
                            android:textColor="#F8FAFC"
                            android:inputType="numberDecimal"
                            android:background="#0B1320"
                            android:paddingHorizontal="16dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:baselineAligned="false">
                    <Button
                        android:id="@+id/btnTrimWithAudio"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="🎵 TRIM (AUDIO)"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2563EB" />
                    <Button
                        android:id="@+id/btnTrimNoAudio"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="🔇 TRIM (NO AUDIO)"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#0891B2" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- LOOP CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#141D2E"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔁 MODE BUTTER LOOP"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#F8FAFC"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Buat loop video dengan berbagai efek"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="12dp"/>
                
                <RadioGroup
                    android:id="@+id/rgLoopMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <RadioButton
                        android:id="@+id/rbLoopNormal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loop A-B (Normal + Audio)\nLoop normal dengan audio bawaan"
                        android:textColor="#E2E8F0"
                        android:buttonTint="#9333EA"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>
                    <RadioButton
                        android:id="@+id/rbLoopTwerk"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Twerk Loop\nEfek video &amp; audio maju mundur halus"
                        android:buttonTint="#9333EA"
                        android:layout_marginBottom="8dp"
                        android:textColor="#E2E8F0"/>
                    <RadioButton
                        android:id="@+id/rbLoopBoomerang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Boomerang\nVideo memantul mundur, audio normal 2x"
                        android:buttonTint="#9333EA"
                        android:textColor="#E2E8F0"/>
                </RadioGroup>

                <EditText
                    android:id="@+id/etLoopDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="50dp"
                    android:textSize="14sp"
                    android:hint="Masukkan target durasi loop (detik)"
                    android:textColorHint="#64748B"
                    android:textColor="#F8FAFC"
                    android:inputType="number"
                    android:background="#0B1320"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="16dp"/>
                <Button
                    android:id="@+id/btnLoop"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="🚀 EKSEKUSI LOOP"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#EA580C" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- MERGE & CONVERT CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#141D2E"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔗 MODE GABUNG &amp; CONVERT"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#F8FAFC"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gabungkan atau konversi video dengan cepat"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="16dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:baselineAligned="false">
                    <Button
                        android:id="@+id/btnMerge"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="🔀 GABUNG (FAST)"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#059669" />
                    <Button
                        android:id="@+id/btnRemux"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="📄 CONVERT MP4"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#0284C7" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="🟢 Status: Standby"
            android:gravity="center"
            android:textColor="#10B981"
            android:textStyle="bold" />

        <!-- CONSOLE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#050811">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="[ root@localhost ~ ]# Output:"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#10B981"
                    android:layout_marginBottom="12dp"/>
                <LinearLayout
                    android:id="@+id/listContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
                <TextView
                    android:id="@+id/tvConsoleLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Menunggu perintah..."
                    android:textColor="#475569"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
