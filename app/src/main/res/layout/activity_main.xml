<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1C"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#111827">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Video Editor Pro"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#F8FAFC"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPreview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#000000"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <VideoView
                    android:id="@+id/videoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"/>

                <TextView
                    android:id="@+id/tvEmptyPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIDAK ADA VIDEO"
                    android:textColor="#475569"
                    android:textStyle="bold"
                    android:layout_gravity="center"/>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">
            
            <SeekBar
                android:id="@+id/seekBarPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#3B82F6"
                android:thumbTint="#3B82F6"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/btnPlayPause"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶"
                    android:textSize="24sp"
                    android:textColor="#3B82F6"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tvPreviewTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00:00.000 / 00:00.000"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#1E293B"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/btnViewFiles"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvActiveFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📹 [Belum ada video]"
                android:textColor="#F8FAFC"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvBatchCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁 0 file dipilih (tap untuk melihat)"
                android:textColor="#64748B"
                android:textSize="11sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnSelectVideo"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="+ VIDEO"
            android:textSize="10sp"
            android:backgroundTint="#3B82F6"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSelectMultiVideo"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="+ BATCH"
            android:textSize="10sp"
            android:backgroundTint="#7C3AED"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0F172A"
        android:weightSum="4">

        <TextView
            android:id="@+id/tabTrim"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="✂️\nTrim"
            android:textSize="12sp"
            android:gravity="center"
            android:textColor="#3B82F6"
            android:background="#1E293B"
            android:clickable="true"/>

        <TextView
            android:id="@+id/tabLoop"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="🔁\nLoop"
            android:textSize="12sp"
            android:gravity="center"
            android:textColor="#64748B"
            android:clickable="true"/>

        <TextView
            android:id="@+id/tabMerge"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="🎬\nGabung"
            android:textSize="12sp"
            android:gravity="center"
            android:textColor="#64748B"
            android:clickable="true"/>

        <TextView
            android:id="@+id/tabConvert"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="🔄\nConvert"
            android:textSize="12sp"
            android:gravity="center"
            android:textColor="#64748B"
            android:clickable="true"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/panelTrim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioGroup 
                        android:id="@+id/rgTrimMode" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:orientation="horizontal" 
                        android:layout_marginBottom="12dp">
                        <RadioButton 
                            android:id="@+id/rbTrimAuto" 
                            android:layout_width="0dp" 
                            android:layout_weight="1" 
                            android:layout_height="wrap_content" 
                            android:text="Auto Split" 
                            android:textColor="#E2E8F0" 
                            android:buttonTint="#3B82F6" 
                            android:checked="true"/>
                        <RadioButton 
                            android:id="@+id/rbTrimCustom" 
                            android:layout_width="0dp" 
                            android:layout_weight="1" 
                            android:layout_height="wrap_content" 
                            android:text="Spesifik" 
                            android:buttonTint="#3B82F6" 
                            android:textColor="#E2E8F0"/>
                    </RadioGroup>

                    <EditText 
                        android:id="@+id/etTrimSegment" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:hint="Durasi per part (detik)" 
                        android:textColor="#FFF" 
                        android:textColorHint="#64748B" 
                        android:background="#1E293B" 
                        android:padding="12dp" 
                        android:inputType="numberDecimal" 
                        android:digits="0123456789."
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout 
                        android:id="@+id/layoutTrimCustom" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:orientation="horizontal" 
                        android:visibility="gone" 
                        android:layout_marginBottom="16dp">
                        <EditText 
                            android:id="@+id/etTrimStart" 
                            android:layout_width="0dp" 
                            android:layout_weight="1" 
                            android:layout_height="wrap_content" 
                            android:hint="Start (misal 5.0)" 
                            android:textColor="#FFF" 
                            android:background="#1E293B" 
                            android:padding="12dp" 
                            android:layout_marginEnd="4dp" 
                            android:inputType="numberDecimal"
                            android:digits="0123456789."
                            android:imeOptions="actionDone"
                            android:maxLines="1"/>
                        <EditText 
                            android:id="@+id/etTrimEnd" 
                            android:layout_width="0dp" 
                            android:layout_weight="1" 
                            android:layout_height="wrap_content" 
                            android:hint="End (misal 15.0)" 
                            android:textColor="#FFF" 
                            android:background="#1E293B" 
                            android:padding="12dp" 
                            android:layout_marginStart="4dp" 
                            android:inputType="numberDecimal"
                            android:digits="0123456789."
                            android:imeOptions="actionDone"
                            android:maxLines="1"/>
                    </LinearLayout>

                    <Button 
                        android:id="@+id/btnTrimWithAudio" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="✂️ EKSEKUSI TRIM (AUDIO)" 
                        android:backgroundTint="#2563EB" 
                        android:layout_marginBottom="8dp"/>
                    <Button 
                        android:id="@+id/btnTrimNoAudio" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="✂️ EKSEKUSI TRIM (NO AUDIO)" 
                        android:backgroundTint="#0891B2"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panelLoop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <RadioGroup 
                        android:id="@+id/rgLoopMode" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:layout_marginBottom="12dp">
                        <RadioButton 
                            android:id="@+id/rbLoopNormal" 
                            android:layout_width="match_parent" 
                            android:layout_height="wrap_content" 
                            android:text="Loop A-B (Normal)" 
                            android:buttonTint="#9333EA" 
                            android:textColor="#E2E8F0" 
                            android:checked="true"/>
                        <RadioButton 
                            android:id="@+id/rbLoopTwerk" 
                            android:layout_width="match_parent" 
                            android:layout_height="wrap_content" 
                            android:text="Twerk Mode" 
                            android:buttonTint="#9333EA" 
                            android:textColor="#E2E8F0"/>
                        <RadioButton 
                            android:id="@+id/rbLoopBoomerang" 
                            android:layout_width="match_parent" 
                            android:layout_height="wrap_content" 
                            android:text="Boomerang Mode" 
                            android:buttonTint="#9333EA" 
                            android:textColor="#E2E8F0"/>
                    </RadioGroup>

                    <EditText 
                        android:id="@+id/etLoopDuration" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:hint="Target durasi (detik)" 
                        android:textColor="#FFF" 
                        android:textColorHint="#64748B" 
                        android:background="#1E293B" 
                        android:padding="12dp" 
                        android:inputType="numberDecimal"
                        android:digits="0123456789."
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:layout_marginBottom="16dp"/>

                    <Button 
                        android:id="@+id/btnLoop" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="🔁 EKSEKUSI LOOP" 
                        android:backgroundTint="#EA580C"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panelMerge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="Gabungkan semua file batch (Fast Concat)" 
                        android:textColor="#94A3B8" 
                        android:layout_marginBottom="16dp"/>
                    <Button 
                        android:id="@+id/btnMerge" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="🎬 GABUNG VIDEO" 
                        android:backgroundTint="#059669"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panelConvert"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="Konversi batch ke standar MP4 (H.264/AAC)" 
                        android:textColor="#94A3B8" 
                        android:layout_marginBottom="16dp"/>
                    <Button 
                        android:id="@+id/btnRemux" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="🔄 CONVERT BATCH" 
                        android:backgroundTint="#0284C7"/>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/listContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#050811">
        <ProgressBar 
            android:id="@+id/progressBar" 
            android:layout_width="24dp" 
            android:layout_height="24dp" 
            android:layout_gravity="center" 
            android:visibility="gone"/>
        <TextView 
            android:id="@+id/tvStatus" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:text="🟢 Siap" 
            android:textColor="#10B981" 
            android:gravity="center" 
            android:textSize="12sp" 
            android:layout_marginTop="4dp"/>
    </LinearLayout>

</LinearLayout>
