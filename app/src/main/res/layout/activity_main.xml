<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">

    <FrameLayout android:id="@+id/fragment_container" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#1E1E1E" android:scrollbars="none">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="8dp">
            <Button android:id="@+id/nav_request" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Req" />
            <Button android:id="@+id/nav_download" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DL" />
            <Button android:id="@+id/nav_browser" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Web" />
            <Button android:id="@+id/nav_extractor" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M3U8" />
            <Button android:id="@+id/nav_history" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hist" />
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
