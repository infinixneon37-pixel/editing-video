<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#111827"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✂️ MODE POTONG (TRIM)"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#F8FAFC"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/rgTrimMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">
        <RadioButton
            android:id="@+id/rbTrimAuto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto Split (Potong berkali-kali per part)"
            android:textColor="#E2E8F0"
            android:buttonTint="#3B82F6"
            android:checked="true"
            android:layout_marginBottom="8dp"/>
        <RadioButton
            android:id="@+id/rbTrimCustom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Spesifik (Potong dari titik Start ke End)"
            android:buttonTint="#3B82F6"
            android:textColor="#E2E8F0"/>
    </RadioGroup>

    <LinearLayout
        android:id="@+id/layoutTrimAuto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">
        <EditText
            android:id="@+id/etTrimSegment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:textSize="14sp"
            android:hint="Durasi per part (detik)"
            android:textColorHint="#64748B"
            android:textColor="#F8FAFC"
            android:inputType="numberDecimal"
            android:background="#0A0F1C"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutTrimCustom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">
            <EditText
                android:id="@+id/etTrimStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="50dp"
                android:layout_marginEnd="6dp"
                android:textSize="14sp"
                android:hint="Start (misal: 5.063)"
                android:textColorHint="#64748B"
                android:textColor="#F8FAFC"
                android:inputType="numberDecimal"
                android:background="#0A0F1C"
                android:paddingHorizontal="16dp"/>
            <EditText
                android:id="@+id/etTrimEnd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:minHeight="50dp"
                android:textSize="14sp"
                android:hint="End (misal: 6.838)"
                android:textColorHint="#64748B"
                android:textColor="#F8FAFC"
                android:inputType="numberDecimal"
                android:background="#0A0F1C"
                android:paddingHorizontal="16dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="16dp">
        <Button
            android:id="@+id/btnTrimWithAudio"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="♪ TRIM (AUDIO)"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2563EB" />
        <Button
            android:id="@+id/btnTrimNoAudio"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="🔇 TRIM (NO AUDIO)"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0891B2" />
    </LinearLayout>
</LinearLayout>
