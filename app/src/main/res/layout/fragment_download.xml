<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" 
    android:layout_height="match_parent" 
    android:orientation="vertical" 
    android:padding="16dp">

    <TextView 
        android:layout_width="wrap_content" 
        android:layout_height="wrap_content" 
        android:text="Multi-Thread Downloader" 
        android:textSize="20sp" 
        android:textStyle="bold" />

    <EditText 
        android:id="@+id/editDlUrl" 
        android:layout_width="match_parent" 
        android:layout_height="wrap_content" 
        android:hint="URL to download" 
        android:layout_marginTop="12dp"/>

    <EditText 
        android:id="@+id/editFileName" 
        android:layout_width="match_parent" 
        android:layout_height="wrap_content" 
        android:hint="Filename (e.g. video.mp4)" 
        android:layout_marginTop="8dp"/>

    <Button 
        android:id="@+id/btnStartDownload" 
        android:layout_width="match_parent" 
        android:layout_height="wrap_content" 
        android:text="START SEGMENTED DOWNLOAD" 
        android:layout_marginTop="16dp" />

    <TextView 
        android:id="@+id/txtDlStatus" 
        android:layout_width="match_parent" 
        android:layout_height="wrap_content" 
        android:text="Status: Idle" 
        android:layout_marginTop="16dp" 
        android:textStyle="bold" 
        android:textColor="#006600"/>

</LinearLayout>
